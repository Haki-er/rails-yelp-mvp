<div class="row justify-content-center">
  <div class="col-md-8">
    <%= link_to "← Back to all restaurants", restaurants_path, class: "text-muted text-decoration-none mb-4 d-block" %>

    <div class="mb-5">
      <h1 class="display-5 fw-bold"><%= @restaurant.name %></h1>
      <p class="fs-5 text-secondary"><%= @restaurant.category.capitalize %> • <%= @restaurant.address %></p>
      <p class="text-muted"><i class="fa-solid fa-phone"></i> <%= @restaurant.phone_number %></p>
    </div>

    <div class="row">
      <div class="col-md-7">
        <h4 class="fw-bold mb-4">Reviews</h4>
        <% if @restaurant.reviews.any? %>
          <% @restaurant.reviews.each do |review| %>
            <% if review.persisted? %>
              <div class="border-bottom pb-3 mb-3">
                <div class="text-warning mb-1">
                  <% review.rating.times do %>★<% end %><% (5 - review.rating).times do %>☆<% end %>
                </div>
                <p class="mb-0">"<%= review.content %>"</p>
              </div>
            <% end %>
          <% end %>
        <% else %>
          <p class="text-muted italic">No reviews yet.</p>
        <% end %>
      </div>

      <div class="col-md-5">
        <div class="custom-card bg-light border-0 p-4">
          <h5 class="fw-bold mb-3">Post a Review</h5>
          <%= simple_form_for [@restaurant, @review] do |f| %>
            <%= f.input :content, label: false, placeholder: "Your thoughts..." %>
            <%= f.input :rating, collection: 0..5, label: "Rating", prompt: "How many stars?" %>
            <%= f.button :submit, "Post Review", class: "btn btn-yelp w-100" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
