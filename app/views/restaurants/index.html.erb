<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="fw-bold">Restaurants</h1>
</div>

<div class="row">
  <% @restaurants.each do |restaurant| %>
  <div class="col-md-4 mb-4">
    <div class="custom-card shadow-sm">
      <h5 class="fw-bold mb-1"><%= restaurant.name %></h5>
      <span class="badge bg-light text-dark border mb-2"
        ><%= restaurant.category.capitalize %></span
      >
      <p class="text-muted small"><%= restaurant.address %></p>
      <%= link_to "See details →", restaurant_path(restaurant), class:
      "stretched-link text-decoration-none text-danger fw-bold" %>
    </div>
  </div>
  <% end %>
</div>
