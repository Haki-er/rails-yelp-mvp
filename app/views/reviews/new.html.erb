<h1>Add a review for <%= @restaurant.name %></h1>

<%= simple_form_for([@restaurant, @review]) do |f| %>
  <%= f.input :content %>
  <%= f.input :rating, collection: 0..5 %>
  <%= f.button :submit, "Submit Review", class: "btn-custom-submit w-100" %>
<% end %>

<%= link_to "Cancel", restaurant_path(@restaurant) %>
